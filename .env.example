# EchoMind environment configuration
# Copy to .env and fill in values

# ─── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
API_CORS_ORIGINS=http://localhost:3000

# ─── Database (Postgres in prod, SQLite locally) ────────────────────────────
DATABASE_URL=sqlite:///./echomind.db
# DATABASE_URL=postgresql+psycopg://echomind:echomind@localhost:5432/echomind

# ─── Vector DB ──────────────────────────────────────────────────────────────
# "local" uses on-disk Qdrant client (no server); "server" uses QDRANT_URL
QDRANT_MODE=local
QDRANT_PATH=./qdrant_storage
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Cache ──────────────────────────────────────────────────────────────────
# "memory" or redis url. memory is fine for local dev.
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# ─── Models ─────────────────────────────────────────────────────────────────
WHISPER_MODEL=tiny           # tiny | base | small | medium | large-v3
TEXT_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
AUDIO_EMBED_MODEL=laion/clap-htsat-unfused
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
MODEL_CACHE_DIR=./models/cache

# ─── RAG / LLM ──────────────────────────────────────────────────────────────
# Provider: "openai" | "anthropic" | "ollama" | "nvidia" | "mock"
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434
# NVIDIA NIM free tier (https://build.nvidia.com) — e.g. minimaxai/minimax-m3
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ─── Storage ────────────────────────────────────────────────────────────────
# Local filesystem or S3-compatible
STORAGE_BACKEND=local
STORAGE_PATH=./data
S3_BUCKET=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── MLflow ─────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns

# ─── Telemetry ──────────────────────────────────────────────────────────────
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090
